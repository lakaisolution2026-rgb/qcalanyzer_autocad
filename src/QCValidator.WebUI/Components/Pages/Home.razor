@page "/"
@rendermode InteractiveServer
@using QCValidator.Application.Interfaces
@using QCValidator.Application.Services
@using QCValidator.Domain.Models
@using QCValidator.Infrastructure.Providers
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@inject ITemplateProvider TemplateProvider
@inject IReportGenerator ReportGenerator
@inject IJSRuntime JSRuntime

<div class="dashboard-container">
    <div class="premium-card animate-fade-in">
        <h1 class="vibrant-header">Drawing Health Check</h1>
        <p class="subtitle">Ensuring AutoCAD standard compliance (2 Essential Rules).</p>

        <label for="fileInput" class="upload-zone">
            <span style="font-size: 3rem; color: var(--primary);">📁</span>
            <h3 style="margin: 1rem 0;">@(selectedFiles.Count == 0 ? "Select AutoCAD (.dwg) File(s)" : $"{selectedFiles.Count} file(s) selected")</h3>
            <p style="color: var(--text-secondary);">Click to browse and select your .dwg drawings.</p>
            <InputFile id="fileInput" OnChange="OnInputFileChange" hidden multiple accept=".dwg" />
        </label>

        @if (isProcessing)
        {
            <div style="text-align: center; margin-top: 2rem;">
                <div class="spinner"></div>
                <p style="color: var(--accent); font-weight: 600;">Analyzing drawing database...</p>
            </div>
        }
        else if (report != null)
        {
            <div class="animate-fade-in" style="margin-top: 3rem;">
                <div class="summary-score">
                    <div class="score-circle">@(Math.Max(0, 100 - report.Errors.Sum(e => e.Locations.Count) * 5))%</div>
                    <div>
                        <h2 style="margin: 0;">Validation Summary</h2>
                        <p style="color: var(--text-secondary); margin-top: 0.25rem;">@(report.Summary)</p>
                    </div>
                </div>

                <div class="vibrant-header" style="font-size: 1.5rem; margin-top: 2rem;">Consolidated Errors</div>
                
                @if (report.Errors.Count == 0)
                {
                    <div class="premium-card" style="text-align: center; background: rgba(16, 185, 129, 0.05);">
                        <span style="font-size: 2rem; color: var(--success);">🏆</span>
                        <h3 style="color: var(--success);">All checks passed! No Layer 0 or Text Style issues found.</h3>
                    </div>
                }
                else
                {
                    var layer0Errors = report.Errors.Where(e => e.Category == "Layer 0 Rule").ToList();
                    var styleErrors  = report.Errors.Where(e => e.Category == "Text Style Rule").ToList();

                    @* ── Layer 0 Card ── *@
                    @if (layer0Errors.Any())
                    {
                        var l0 = layer0Errors.First();
                        <div class="premium-card animate-fade-in" style="margin-bottom: 1.5rem; border-left: 4px solid var(--warning);">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <div>
                                    <span class="badge badge-warning">Warning</span>
                                    <strong style="margin-left: 0.5rem; color: var(--text-primary);">Layer 0 Rule</strong>
                                    <p style="color: var(--text-secondary); margin: 0.5rem 0;">@(l0.Message)</p>
                                </div>
                                <div style="text-align: right;">
                                    <span style="font-size: 1.5rem; font-weight: 800; color: var(--primary);">@(l0.Locations.Count)</span>
                                    <span style="color: var(--text-secondary); display: block;">Entities on Layer 0</span>
                                </div>
                            </div>
                            <details style="margin-top: 1rem; border-top: 1px solid var(--border); padding-top: 1rem;">
                                <summary style="cursor: pointer; color: var(--accent); font-weight: 600;">📍 View all locations & AutoCAD Zoom commands</summary>
                                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1rem; margin-top: 1rem;">
                                    @foreach (var loc in l0.Locations)
                                    {
                                        <div style="background: rgba(255,255,255,0.03); padding: 1rem; border-radius: 0.75rem; border: 1px solid var(--border); display: flex; flex-direction: column; gap: 0.5rem;">
                                            <div style="display: flex; justify-content: space-between; align-items: start;">
                                                <div>
                                                    <div style="font-size: 0.75rem; color: var(--text-secondary); text-transform: uppercase;">@(loc.Space)</div>
                                                    <div class="coordinate">@(Math.Round(loc.X, 2)), @(Math.Round(loc.Y, 2))</div>
                                                </div>
                                                <button class="copy-btn" @onclick="() => CopyZoomCommand(loc.X, loc.Y)">Copy Zoom</button>
                                            </div>
                                            <div style="background: rgba(0,0,0,0.2); padding: 0.5rem; border-radius: 0.4rem; border-left: 3px solid var(--accent);">
                                                <div style="font-size: 0.7rem; color: var(--text-secondary);">Content:</div>
                                                <div style="font-weight: 600; font-family: 'JetBrains Mono'; font-size: 0.9rem;">@(loc.TextContent)</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </details>
                        </div>
                    }

                    @* ── Text Style Card (all non-compliant styles grouped) ── *@
                    @if (styleErrors.Any())
                    {
                        int totalStyleViolations = styleErrors.Sum(e => e.Locations.Count);
                        <div class="premium-card animate-fade-in" style="margin-bottom: 1.5rem; border-left: 4px solid var(--error);">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <div>
                                    <span class="badge badge-error">Error</span>
                                    <strong style="margin-left: 0.5rem; color: var(--text-primary);">Text Style Rule</strong>
                                    <p style="color: var(--text-secondary); margin: 0.5rem 0;">Non-compliant text styles found. Only <strong>Arial</strong>, <strong>Arial Narrow</strong>, or <strong>Standard</strong> are permitted.</p>
                                </div>
                                <div style="text-align: right;">
                                    <span style="font-size: 1.5rem; font-weight: 800; color: var(--primary);">@(totalStyleViolations)</span>
                                    <span style="color: var(--text-secondary); display: block;">Total Violations</span>
                                </div>
                            </div>

                            @foreach (var styleErr in styleErrors)
                            {
                                <details style="margin-top: 1rem; border-top: 1px solid var(--border); padding-top: 1rem;">
                                    <summary style="cursor: pointer; color: var(--error); font-weight: 600;">
                                        🔤 Style: <code style="background: rgba(239,68,68,0.1); padding: 0.2rem 0.5rem; border-radius: 0.3rem;">@(styleErr.Message.Split("'")[1])</code>
                                        — @(styleErr.Locations.Count) occurrence(s)
                                    </summary>
                                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1rem; margin-top: 1rem;">
                                        @foreach (var loc in styleErr.Locations)
                                        {
                                            <div style="background: rgba(255,255,255,0.03); padding: 1rem; border-radius: 0.75rem; border: 1px solid var(--border); display: flex; flex-direction: column; gap: 0.5rem;">
                                                <div style="display: flex; justify-content: space-between; align-items: start;">
                                                    <div>
                                                        <div style="font-size: 0.75rem; color: var(--text-secondary); text-transform: uppercase;">@(loc.Space)</div>
                                                        <div class="coordinate">@(Math.Round(loc.X, 2)), @(Math.Round(loc.Y, 2))</div>
                                                    </div>
                                                    <button class="copy-btn" @onclick="() => CopyZoomCommand(loc.X, loc.Y)">Copy Zoom</button>
                                                </div>
                                                <div style="background: rgba(0,0,0,0.2); padding: 0.5rem; border-radius: 0.4rem; border-left: 3px solid var(--error);">
                                                    <div style="font-size: 0.7rem; color: var(--text-secondary);">Text Content:</div>
                                                    <div style="font-weight: 600; font-family: 'JetBrains Mono'; font-size: 0.9rem;">@(loc.TextContent)</div>
                                                    <div style="font-size: 0.7rem; color: var(--error); margin-top: 0.4rem;">
                                                        Style used: <strong>@(loc.FoundStyle)</strong> → must be Arial, Arial Narrow, or Standard
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </details>
                            }
                        </div>
                    }
                }

                <div class="animate-fade-in" style="margin-top: 3rem;">
                    <div class="premium-card" style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--border);">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                            <h3 style="margin: 0; color: var(--accent);">📊 RAW System Data (Inspection JSON)</h3>
                            <button class="copy-btn" @onclick="CopyJsonToClipboard">Copy JSON</button>
                        </div>
                        <pre style="background: rgba(0,0,0,0.3); padding: 1.5rem; border-radius: 0.75rem; overflow-x: auto; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: #a5f3fc; max-height: 400px; border: 1px solid rgba(34, 211, 238, 0.1);">
                            @(rawJson)
                        </pre>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<IBrowserFile> selectedFiles = new();
    private bool isProcessing = false;
    private QCReport? report;
    private string rawJson = "";

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        selectedFiles = e.GetMultipleFiles(500).ToList();
        if (selectedFiles.Any())
        {
            await ProcessFiles();
        }
    }

    private async Task ProcessFiles()
    {
        isProcessing = true;
        rawJson = "";
        StateHasChanged();

        try
        {
            var allErrors = new List<QCError>();
            var summaries = new List<string>();
            string lastFileName = "";

            foreach (var file in selectedFiles.Where(f => f.Name.EndsWith(".dwg", StringComparison.OrdinalIgnoreCase)))
            {
                lastFileName = file.Name;
                var tempPath = Path.Combine(Path.GetTempPath(), file.Name);
                
                try 
                {
                    using (var stream = file.OpenReadStream(100 * 1024 * 1024))
                    using (var fs = new FileStream(tempPath, FileMode.Create))
                    {
                        await stream.CopyToAsync(fs);
                    }

                    var drawingProvider = new AutoCadDrawingProvider(tempPath);
                    var service = new QCValidationService(drawingProvider, TemplateProvider, ReportGenerator);
                    
                    var reportPath = service.Run(file.Name);
                    if (File.Exists(reportPath))
                    {
                        var fileJson = File.ReadAllText(reportPath);
                        rawJson += $"--- File: {file.Name} ---\n{fileJson}\n\n";
                        
                        var subReport = JsonSerializer.Deserialize<QCReport>(fileJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                        if (subReport != null)
                        {
                            allErrors.AddRange(subReport.Errors);
                            if (!string.IsNullOrEmpty(subReport.Summary)) summaries.Add($"{file.Name}: {subReport.Summary}");
                        }
                        File.Delete(reportPath);
                    }
                }
                finally {
                    if (File.Exists(tempPath)) File.Delete(tempPath);
                }
            }

            report = new QCReport(
                selectedFiles.Count > 1 ? "Multiple Drawing Inspection" : lastFileName,
                DateTime.Now,
                string.Join(" | ", summaries),
                allErrors
            );
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task CopyZoomCommand(double x, double y)
    {
        var cmd = $"-ZOOM C {Math.Round(x, 2)},{Math.Round(y, 2)} 100";
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", cmd);
    }

    private async Task CopyJsonToClipboard()
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", rawJson);
    }
}
